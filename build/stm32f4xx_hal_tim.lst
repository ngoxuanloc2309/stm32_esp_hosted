7530:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   * @param  TIMx to select the TIM peripheral
7531:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   * @param  TIM_ExtTRGPrescaler The external Trigger Prescaler.
7532:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *          This parameter can be one of the following values:
7533:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *            @arg TIM_ETRPRESCALER_DIV1: ETRP Prescaler OFF.
7534:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *            @arg TIM_ETRPRESCALER_DIV2: ETRP frequency divided by 2.
7535:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *            @arg TIM_ETRPRESCALER_DIV4: ETRP frequency divided by 4.
7536:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *            @arg TIM_ETRPRESCALER_DIV8: ETRP frequency divided by 8.
7537:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   * @param  TIM_ExtTRGPolarity The external Trigger Polarity.
7538:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *          This parameter can be one of the following values:
7539:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *            @arg TIM_ETRPOLARITY_INVERTED: active low or falling edge active.
7540:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *            @arg TIM_ETRPOLARITY_NONINVERTED: active high or rising edge active.
7541:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   * @param  ExtTRGFilter External Trigger Filter.
7542:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   *          This parameter must be a value between 0x00 and 0x0F
7543:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   * @retval None
7544:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c ****   */
